# =============================================================================
# Project Root .gitignore
# =============================================================================

# =============================================================================
# Terraform-Related Files (Root Level)
# =============================================================================
*.tfstate
*.tfstate.*
cluster-key.pem
cluster-key*
kubeconfig-*.yaml
rke2-token-*.txt
tfplan

# =============================================================================
# IDE / Editor Files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS-Specific Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Logs and Temporary Files
# =============================================================================
*.log
logs/
*.out
*.tmp
*.temp
*.bak
temp/
tmp/

# =============================================================================
# Environment Files
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Node/NPM (if applicable)
# =============================================================================
node_modules/
npm-debug.log
yarn.lock
package-lock.json

# =============================================================================
# Python-Related (if applicable)
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/

# =============================================================================
# Documentation Build Artifacts
# =============================================================================
docs/_build/
site/

# =============================================================================
# SSH Keys (critical security)
# =============================================================================
*.pem
*.key
!*.pub
.ssh/

# =============================================================================
# Kubeconfig Files
# =============================================================================
*.kubeconfig
kubeconfig
.kube/
