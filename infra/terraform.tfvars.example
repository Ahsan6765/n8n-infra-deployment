# =============================================================================
# Terraform Variables - Example Configuration
# Copy this file and customize for your environment
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Update values with your actual configuration
# 3. Do NOT commit terraform.tfvars files (they contain sensitive data)
# 4. Use: terraform apply -var-file="terraform.tfvars"
# =============================================================================
# IMPORTANT: All variables are REQUIRED (no defaults in variables.tf)
# Every value below MUST be provided in your tfvars file
# =============================================================================

# =============================================================================
# General Configuration (REQUIRED)
# =============================================================================
aws_region   = "us-east-1"
project_name = "n8n-k8s"
environment  = "dev"
owner        = "platform-team"

# =============================================================================
# VPC / Networking Configuration (REQUIRED)
# =============================================================================
# Environment-specific VPC allocation:
# Dev: 10.0.0.0/16 with subnets 10.0.1-3.0/24
# Staging: 10.1.0.0/16 with subnets 10.1.1-3.0/24
# Production: 10.2.0.0/16 with subnets 10.2.1-3.0/24
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
availability_zones  = ["us-east-1a", "us-east-1b", "us-east-1c"]

# =============================================================================
# SSH Key Pair Configuration (OPTIONAL - empty = auto-generate)
# =============================================================================
# Leave empty "" to auto-generate a key pair
# Provide "ssh-rsa AAAA..." to use your existing public key
ssh_public_key = ""

# =============================================================================
# EC2 Nodes Configuration (REQUIRED)
# =============================================================================
# Instance type options: t3.small, t3.medium, t3.large, t3.xlarge
master_instance_type = "t3.medium"
worker_instance_type = "t3.medium"

# Node scaling configuration
master_count = 1
worker_count = 3

# Storage configuration for root volumes
node_volume_size = 50
node_volume_type = "gp3"

# SSH access control (REQUIRED - must be set)
# Dev: 0.0.0.0/0 (open to all)
# Staging: 10.0.0.0/8 (restricted to internal VPC)
# Production: YOUR.IP.ADDRESS/32 (your specific IP only)
admin_ssh_cidr = "0.0.0.0/0"

# =============================================================================
# S3 State + Artifacts Configuration (REQUIRED)
# =============================================================================
# Note: Bucket names must be globally unique across AWS
# Recommendation: Use environment suffix (-dev, -staging, -prod)
state_bucket_name     = "n8n-k8s-tf-state"
artifact_bucket_name  = "n8n-k8s-artifacts"
state_lock_table_name = "n8n-k8s-tf-lock"

# =============================================================================
# Route 53 / DNS Configuration (REQUIRED)
# =============================================================================
# Domain name for your Kubernetes cluster API
domain_name         = "k8s.example.com"
# Set to false if using existing hosted zone
create_route53_zone = true

# =============================================================================
# RKE2 Kubernetes Configuration (REQUIRED)
# =============================================================================
# RKE2 release version (e.g., v1.29, v1.30, latest)
rke2_version = "v1.29"
